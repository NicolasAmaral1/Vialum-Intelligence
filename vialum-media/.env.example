# Database (same Postgres as CRM Hub, different database)
DATABASE_URL=postgresql://user:pass@vialumchat-db:5432/vialum_media

# Auth (SAME JWT_SECRET as CRM Hub and Vialum Chat — shared auth)
JWT_SECRET=same-as-crm-hub-and-chat

# S3 Storage (MinIO)
S3_ACCESS_KEY=vialum-admin
S3_SECRET_KEY=your-minio-password
S3_ENDPOINT=http://vialum-minio:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET=vialum-media

# Optional
CORS_ORIGIN=*
