# ── Database ──
DB_PASSWORD=

# ── Redis ──
REDIS_PASSWORD=

# ── JWT ──
JWT_SECRET=                    # min 32 chars — used for API auth + Media Service auth
JWT_REFRESH_SECRET=            # min 32 chars

# ── AI Providers ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── CORS ──
CORS_ORIGIN=http://localhost:3000  # comma-separated for multiple origins

# ── Vialum Media Service ──
MEDIA_SERVICE_URL=http://vialum-media:3002/media
MEDIA_JWT_SECRET=              # min 32 chars — shared with Media Service JWT_SECRET

# ── Vialum Hub (CRM) ──
HUB_URL=                       # e.g. http://vialum-crm-hub:3001

# ── Vialum Switch ──
SWITCH_WEBHOOK_SECRET=

# ── Vialum Tasks ──
WEBHOOK_SECRET=                # shared secret for Tasks webhook notifications

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_URL=http://localhost:4000/chat
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXTAUTH_SECRET=
