generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════
// HUB CONTACTS — Universal identity, source-agnostic
// ════════════════════════════════════════════════════════════

model CrmContact {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalSourceId String?  @map("external_source_id") @db.VarChar(255) // ID in the source service (e.g., Chat contact UUID)
  externalSource   String?  @map("external_source") @db.VarChar(50)     // Source service: vialum_chat, vialum_portal, etc.
  accountId        String   @map("account_id") @db.Uuid
  phone            String?  @db.VarChar(50)
  email            String?  @db.VarChar(255)
  name             String?  @db.VarChar(255)
  nameSource       String   @default("unknown") @map("name_source") @db.VarChar(30) // whatsapp | chat | task | crm | manual
  tags             String[] @default([])
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  aliases       ContactAlias[]
  integrations  CrmIntegration[]
  groupMappings WhatsAppGroupMapping[]
  organizations ContactOrganization[]

  @@index([accountId])
  @@index([phone])
  @@index([email])
  @@index([accountId, phone])
  @@index([accountId, externalSourceId, externalSource])
  @@map("crm_contacts")
}

// ════════════════════════════════════════════════════════════
// ORGANIZATIONS — Companies, PJ entities
// ════════════════════════════════════════════════════════════

model CrmOrganization {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  legalName      String?  @map("legal_name") @db.VarChar(500)
  tradeName      String?  @map("trade_name") @db.VarChar(500)
  cnpj           String?  @db.VarChar(20)
  lifecycleStage String   @default("lead") @map("lifecycle_stage") @db.VarChar(50)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  aliases  OrganizationAlias[]
  contacts ContactOrganization[]

  @@unique([accountId, cnpj])
  @@index([accountId])
  @@map("crm_organizations")
}

model OrganizationAlias {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  type           String   @db.VarChar(30)
  value          String   @db.VarChar(255)
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization CrmOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([accountId, type, value])
  @@index([accountId, value])
  @@map("organization_aliases")
}

model ContactOrganization {
  contactId      String   @map("contact_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  role           String   @default("representante") @db.VarChar(100)
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  contact      CrmContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization CrmOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([contactId, organizationId])
  @@index([organizationId])
  @@map("contact_organizations")
}

// ════════════════════════════════════════════════════════════
// CONTACT ALIASES — Multi-identifier lookup
// Types: phone, email, cpf, cnpj, pipedrive_person, rdstation_contact, clickup_member, source:*, custom:*
// ════════════════════════════════════════════════════════════

model ContactAlias {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crmContactId String   @map("crm_contact_id") @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  type         String   @db.VarChar(50)   // extensible — any known type or custom:* prefix
  value        String   @db.VarChar(255)  // normalized (phone: E.164, email: lowercase, IDs: raw)
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  contact CrmContact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)

  @@unique([accountId, type, value])
  @@index([accountId, value])
  @@index([crmContactId])
  @@map("contact_aliases")
}

// ════════════════════════════════════════════════════════════
// INTEGRATIONS — Links to external systems (deals, tasks, folders)
// ════════════════════════════════════════════════════════════

model CrmIntegration {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crmContactId  String   @map("crm_contact_id") @db.Uuid
  provider      String   @db.VarChar(50)
  externalId    String   @map("external_id") @db.VarChar(255)
  externalUrl   String?  @map("external_url")
  resourceType  String   @map("resource_type") @db.VarChar(50)
  resourceName  String?  @map("resource_name") @db.VarChar(255)
  status        String?  @db.VarChar(100)
  stage         String?  @db.VarChar(100)
  value         Decimal? @db.Decimal(12, 2)
  active        Boolean  @default(true)  // false when provider is deactivated
  syncedAt      DateTime @default(now()) @map("synced_at") @db.Timestamptz
  rawData       Json     @default("{}") @map("raw_data")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  contact CrmContact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)

  @@unique([crmContactId, provider, externalId])
  @@index([provider])
  @@index([externalId])
  @@map("crm_integrations")
}

// ════════════════════════════════════════════════════════════
// PROVIDER CONFIGS — API keys, tokens, sync settings per tenant
// ════════════════════════════════════════════════════════════

model ProviderConfig {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId  String    @map("account_id") @db.Uuid
  provider   String    @db.VarChar(50)
  category   String    @default("crm") @db.VarChar(30)
  config     Json
  active               Boolean   @default(true)
  lastSyncAt           DateTime? @map("last_sync_at") @db.Timestamptz
  syncIntervalMinutes  Int       @default(240) @map("sync_interval_minutes") // 0 = disabled
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([accountId, provider])
  @@index([accountId, category, active])
  @@map("provider_configs")
}

// ════════════════════════════════════════════════════════════
// OAUTH TOKENS — Generic token storage with auto-refresh
// ════════════════════════════════════════════════════════════

model OAuthToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String    @map("account_id") @db.Uuid
  provider     String    @db.VarChar(50)
  accessToken  String    @map("access_token") @db.Text
  refreshToken String?   @map("refresh_token") @db.Text
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  tokenType    String    @default("Bearer") @map("token_type") @db.VarChar(30)
  scope        String?   @db.Text
  rawResponse  Json      @default("{}") @map("raw_response")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([accountId, provider])
  @@map("oauth_tokens")
}

// ════════════════════════════════════════════════════════════
// WHATSAPP GROUP MAPPINGS — Links groups to Hub contacts
// ════════════════════════════════════════════════════════════

model WhatsAppGroupMapping {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  crmContactId String   @map("crm_contact_id") @db.Uuid
  groupJid     String   @map("group_jid") @db.VarChar(100)
  groupName    String?  @map("group_name") @db.VarChar(255)
  groupType    String   @default("client") @map("group_type") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  contact CrmContact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)

  @@unique([accountId, groupJid])
  @@index([crmContactId])
  @@map("whatsapp_group_mappings")
}

// ════════════════════════════════════════════════════════════
// PROVIDER OPERATIONS — Audit trail for all write operations
// ════════════════════════════════════════════════════════════

model ProviderOperation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId  String   @map("account_id") @db.Uuid
  provider   String   @db.VarChar(50)
  category   String   @db.VarChar(30)
  operation  String   @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.VarChar(255)
  params     Json     @default("{}")
  result     Json?
  status     String   @db.VarChar(20)
  error      String?  @db.Text
  caller     String?  @db.VarChar(100)
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([accountId, createdAt(sort: Desc)])
  @@index([accountId, provider, entityId])
  @@index([accountId, caller, createdAt(sort: Desc)])
  @@map("provider_operations")
}
