# MinIO Root Credentials
MINIO_ROOT_USER=vialum-admin
MINIO_ROOT_PASSWORD=change-this-strong-password-here

# Region (match AWS region if planning migration)
MINIO_REGION=us-east-1

# Ports (change if conflicts)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------
# S3-COMPATIBLE CONFIG (used by all services)
# ---------------------------------------------------
# When self-hosted (MinIO):
S3_ENDPOINT=http://vialum-minio:9000
S3_ACCESS_KEY=vialum-admin
S3_SECRET_KEY=change-this-strong-password-here
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# When migrating to AWS S3, change to:
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=<AWS_ACCESS_KEY_ID>
# S3_SECRET_KEY=<AWS_SECRET_ACCESS_KEY>
# S3_REGION=sa-east-1
# S3_FORCE_PATH_STYLE=false
